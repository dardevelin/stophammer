# Stophammer node configuration
# Copy to /etc/stophammer/env and fill in values.
# For Docker, pass as environment variables or an env_file.

# ── Core ─────────────────────────────────────────────────────────────────────

# "primary" (default) or "community"
NODE_MODE=primary

# Path to the SQLite database file. Use a persistent volume in Docker.
DB_PATH=/var/lib/stophammer/stophammer.db

# Path to the ed25519 signing key. Generated on first start if absent.
# IMPORTANT: Back up this file. The signing key identifies this node permanently.
# Losing it means new events cannot be verified by nodes that trusted the old key.
# Use a persistent volume or bind-mount in Docker to survive container restarts.
KEY_PATH=/var/lib/stophammer/signing.key

# Socket address to bind. Format: ip:port
BIND=0.0.0.0:8008

# Shared secret for crawler authentication (POST /ingest/feed).
# Required in primary mode. Compared in constant time (SHA-256).
CRAWL_TOKEN=change-me-to-a-secret-token

# Token for admin endpoints (X-Admin-Token header).
# Required for /admin/*, DELETE, and PATCH operations.
# If empty, all admin endpoints return 403.
# ADMIN_TOKEN=change-me

# Dedicated token for community node sync registration (X-Sync-Token header).
# Used by POST /sync/register. Separate from ADMIN_TOKEN so community nodes
# cannot access destructive admin endpoints (merge artists, manage aliases, etc.).
# If unset, falls back to ADMIN_TOKEN for backward compatibility (with deprecation warning).
# Both primary and community nodes must share this value.
# SYNC_TOKEN=change-me-to-a-separate-sync-secret

# ── TLS (ACME / Let's Encrypt) ──────────────────────────────────────────────

# Domain (or IP address) to provision a TLS certificate for.
# If unset, the node starts in plain HTTP mode with a log warning.
# See docs/adr/0019-tls-acme-let-s-encrypt.md for the full design.
# TLS_DOMAIN=node.example.com

# Contact email registered with Let's Encrypt.
# Required when TLS_DOMAIN is set.
# TLS_ACME_EMAIL=admin@example.com

# Path to store the provisioned certificate chain.
# TLS_CERT_PATH=./tls/cert.pem

# Path to store the certificate private key (written with 0o600 permissions).
# TLS_KEY_PATH=./tls/key.pem

# Use Let's Encrypt staging environment (for testing without rate limits).
# TLS_ACME_STAGING=false

# Custom ACME directory URL. When set, overrides TLS_ACME_STAGING entirely.
# Useful for testing with Pebble (https://github.com/letsencrypt/pebble):
#   TLS_ACME_DIRECTORY_URL=https://pebble:14000/dir
# If unset, the directory is chosen by TLS_ACME_STAGING (production or staging).
# TLS_ACME_DIRECTORY_URL=

# Path to persist the ACME account credentials across restarts.
# TLS_ACME_ACCOUNT_PATH=./tls/acme-account.json

# ── Community mode ───────────────────────────────────────────────────────────

# Base URL of the primary node. Required when NODE_MODE=community.
# PRIMARY_URL=https://primary.example.com:8008

# Hex-encoded ed25519 pubkey of the primary node.
# If omitted, auto-discovered from GET {PRIMARY_URL}/node/info at startup
# (retries 10x with 2s delay). Set explicitly for extra hardening.
# Retrieve with: curl http://primary:8008/node/info
# PRIMARY_PUBKEY=0805c402f021e6e0dfbb6b2f5d34628f7b166b075a0170e6e5e293c50b3b55e2

# Publicly reachable URL of THIS node. Required when NODE_MODE=community.
# The primary will push events to {NODE_ADDRESS}/sync/push.
# Must be reachable from the primary's network.
# NODE_ADDRESS=https://this-node.example.com:8008

# Cloudflare tracker URL for initial bootstrap peer discovery.
# Default (when unset): https://stophammer-tracker.workers.dev
#   — this is an external Cloudflare Workers service; the node contacts it
#     on startup to register itself and discover other peers.
# To remove the external dependency, either:
#   - Set to a local/self-hosted tracker URL, e.g. TRACKER_URL=http://localhost:9000
#   - Set to an empty string (TRACKER_URL=) to disable tracker registration entirely.
# The tracker is optional — it is only used for initial bootstrap when
# PRIMARY_URL is not yet publicly known. Sync with the primary works
# independently of the tracker.
# TRACKER_URL=https://stophammer-tracker.workers.dev

# How often the fallback poll loop wakes up (seconds).
# The poll only fires if no push has been received in PUSH_TIMEOUT_SECS.
# POLL_INTERVAL_SECS=300

# Seconds of push silence before the fallback poll fires.
# Lower = faster crash recovery. Higher = less noisy polling.
# PUSH_TIMEOUT_SECS=90

# Allow pubkey auto-discovery over plain HTTP.
# ONLY for local development / Docker. In production, use HTTPS or set
# PRIMARY_PUBKEY explicitly.
# ALLOW_INSECURE_PUBKEY_DISCOVERY=false

# ── Rate limiting ────────────────────────────────────────────────────────────

# Requests per second per IP (token bucket refill rate).
# RATE_LIMIT_RPS=50

# Maximum burst size per IP.
# RATE_LIMIT_BURST=100

# ── Security ─────────────────────────────────────────────────────────────────

# Set to "true" when behind a reverse proxy (nginx, Caddy, etc.).
# Uses X-Forwarded-For for client IP extraction.
# When false (default), X-Forwarded-For is ignored to prevent IP spoofing.
# TRUST_PROXY=false

# Restrict CORS Access-Control-Allow-Origin header.
# Default: "*" (any origin). Set to a specific origin in production.
# CORS_ALLOW_ORIGIN=https://app.example.com

# ── Tuning ───────────────────────────────────────────────────────────────────

# How often the background pruner deletes expired proof challenges and
# tokens (seconds). Default: 300 (5 minutes).
# PROOF_PRUNE_INTERVAL_SECS=300

# Comma-separated ordered list of verifiers to run on ingest (primary only).
# Omit to use the default (all built-ins in recommended order).
# Community nodes do NOT run verifiers -- they only verify ed25519 signatures.
#
# Available built-ins:
#   crawl_token       - rejects requests with an invalid crawl token (always first)
#   content_hash      - short-circuits unchanged feeds (no DB write, no event)
#   medium_music      - rejects feeds without podcast:medium=music
#   feed_guid         - rejects malformed or known-bad podcast:guid values
#   v4v_payment       - rejects feeds with no valid V4V payment routes
#   enclosure_type    - warns on video/* MIME type enclosures
#   payment_route_sum - optional strict mode: rejects if splits != 100
#
# VERIFIER_CHAIN=crawl_token,content_hash,medium_music,feed_guid,v4v_payment,enclosure_type

# Tracing filter directive. Controls log verbosity.
# Examples: stophammer=debug, stophammer=trace, stophammer::api=debug,stophammer=info
# RUST_LOG=stophammer=info
