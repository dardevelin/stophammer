# Stophammer node configuration
# Copy to /etc/stophammer/env and fill in values

# Required
CRAWL_TOKEN=change-me-to-a-secret-token

# Optional — defaults shown
DB_PATH=/var/lib/stophammer/stophammer.db
KEY_PATH=/var/lib/stophammer/signing.key
BIND=0.0.0.0:8008

# Node mode: "primary" (default) or "community"
NODE_MODE=primary

# Community mode only (required when NODE_MODE=community)
# PRIMARY_URL=http://primary.example.com:8008
# NODE_ADDRESS=http://mynode.example.com:8008
# TRACKER_URL=https://stophammer-tracker.workers.dev
# POLL_INTERVAL_SECS=30
