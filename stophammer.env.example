# Stophammer node configuration
# Copy to /etc/stophammer/env and fill in values

# Required
CRAWL_TOKEN=change-me-to-a-secret-token

# Optional — defaults shown
DB_PATH=/var/lib/stophammer/stophammer.db
KEY_PATH=/var/lib/stophammer/signing.key
BIND=0.0.0.0:8008

# Node mode: "primary" (default) or "community"
NODE_MODE=primary

# Community mode only (required when NODE_MODE=community)
# PRIMARY_URL=http://primary.example.com:8008
# NODE_ADDRESS=http://mynode.example.com:8008
# TRACKER_URL=https://stophammer-tracker.workers.dev
# POLL_INTERVAL_SECS=30

# Verifier chain — comma-separated list of built-in verifier names, in run order.
# Omit to use the default (all built-ins in recommended order).
# To add a new verifier: implement Verifier in src/verifiers/<name>.rs,
# add the module to src/verifiers/mod.rs, add a match arm in verify::build_chain,
# then include its name here.
#
# Available built-ins:
#   crawl_token       — rejects requests with an invalid crawl token (always run first)
#   content_hash      — short-circuits unchanged feeds (no-op, not a true failure)
#   medium_music      — rejects non-music podcast:medium, warns when absent
#   feed_guid         — rejects known-bad and malformed podcast:guid values
#   payment_route_sum — rejects tracks where Lightning splits do not sum to 100
#   enclosure_type    — warns on video/* MIME type enclosures
#
# VERIFIER_CHAIN=crawl_token,content_hash,medium_music,feed_guid,payment_route_sum,enclosure_type
