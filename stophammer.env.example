# Stophammer node configuration
# Copy to /etc/stophammer/env and fill in values.
# For Docker, pass as environment variables or an env_file.

# ── Required (primary mode) ────────────────────────────────────────────────────

CRAWL_TOKEN=change-me-to-a-secret-token

# ── Optional — defaults shown ──────────────────────────────────────────────────

DB_PATH=/var/lib/stophammer/stophammer.db
KEY_PATH=/var/lib/stophammer/signing.key
BIND=0.0.0.0:8008

# IMPORTANT: Back up KEY_PATH and DB_PATH.
# The signing key is generated once and identifies this node permanently.
# Losing it means new events cannot be verified by nodes that trusted the old key.
# Use a persistent volume or bind-mount in Docker to survive container restarts.

# ── Node mode ─────────────────────────────────────────────────────────────────

# "primary" (default) or "community"
NODE_MODE=primary

# ── Primary mode: optional ────────────────────────────────────────────────────

# ADMIN_TOKEN=change-me        # Required for /admin/* endpoints. Omit to disable.

# ── Community mode: required when NODE_MODE=community ─────────────────────────

# PRIMARY_URL=http://primary.example.com:8008
#   Base URL of the primary node. Used for push registration and fallback poll.

# NODE_ADDRESS=http://this-node.example.com:8008
#   Publicly reachable URL of THIS node. The primary will push events here.
#   Must be reachable from the primary's network.

# ── Community mode: optional ──────────────────────────────────────────────────

# PRIMARY_PUBKEY=<64-char hex ed25519 pubkey>
#   The primary node's signing pubkey. Events signed by any other key are
#   rejected. If omitted, auto-discovered from GET {PRIMARY_URL}/node/info
#   at startup — no manual config needed in most setups.
#   Retrieve with: curl http://primary:8008/node/info

# TRACKER_URL=https://stophammer-tracker.workers.dev
#   Optional: Cloudflare tracker for initial bootstrap. Only needed when
#   PRIMARY_URL is not yet known. Once a node knows the primary URL it can
#   discover all peers via GET {PRIMARY_URL}/sync/peers directly.
#   Defaults to the public Cloudflare worker.

# POLL_INTERVAL_SECS=300
#   How often the fallback poll loop wakes up (default: 300).
#   The poll only fires if no push has been received in PUSH_TIMEOUT_SECS.

# PUSH_TIMEOUT_SECS=90
#   Seconds of push silence before the fallback poll fires (default: 90).
#   Set lower for faster crash recovery; set higher to reduce noisy polling.

# ── Verifier chain (primary mode) ─────────────────────────────────────────────

# Comma-separated list of verifier names, in run order.
# Omit to use the default (all built-ins in recommended order).
# Community nodes do NOT run verifiers — they only verify the ed25519 signature.
# Verifier warnings from the primary are stored in each event as an audit trail.
#
# Available built-ins:
#   crawl_token       — rejects requests with an invalid crawl token (always first)
#   content_hash      — short-circuits unchanged feeds (no DB write, no event)
#   medium_music      — rejects feeds without podcast:medium=music
#   feed_guid         — rejects malformed or known-bad podcast:guid values
#   v4v_payment       — rejects feeds with no valid V4V payment routes
#   enclosure_type    — warns on video/* MIME type enclosures
#   payment_route_sum — optional strict mode: rejects if splits != 100
#
# VERIFIER_CHAIN=crawl_token,content_hash,medium_music,feed_guid,v4v_payment,enclosure_type
