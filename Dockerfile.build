# Multi-arch musl builder for stophammer
# Produces zero-dependency static binaries for x86_64 and aarch64 Linux

FROM rust:1.87-alpine AS builder

RUN apk add --no-cache musl-dev

WORKDIR /build
COPY . .

ARG TARGET=x86_64-unknown-linux-musl
RUN rustup target add ${TARGET} && \
    cargo build --release --target ${TARGET}

# Output: /build/target/${TARGET}/release/stophammer
